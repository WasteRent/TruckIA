        "@tailwindcss/typography": "^0.5.2",
        "autoprefixer": "^10.4.5",
        "axios": "^0.19",
        "cross-env": "^5.1",
        "laravel-mix": "^5.0.9",
        "lodash": "^4.17.13",
        "postcss": "^8.4.12",
        "resolve-url-loader": "^2.3.1",
        "sass": "^1.15.2",
        "sass-loader": "^7.1.0",
        "tailwindcss": "^3.0.24",
        "vue-template-compiler": "^2.6.10"
    },
    "dependencies": {
