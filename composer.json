{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1.0",
        "blade-ui-kit/blade-ui-kit": "^0.6.2",
        "chillerlan/php-qrcode": "^4.3",
        "guzzlehttp/guzzle": "^7.0.1",
        "halaxa/json-machine": "^1.1",
        "hashids/hashids": "^4.1",
        "kkomelin/laravel-translatable-string-exporter": "^1.16",
        "knplabs/knp-snappy": "^1.4",
        "laravel/framework": "^10.0",
        "laravel/helpers": "^1.1",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.0",
        "laravelcollective/html": "^6.3",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "mydnic/laravel-kustomer": "^1.10",
        "openai-php/client": "^0.10.1",
        "owen-it/laravel-auditing": "^13.5",
        "spatie/browsershot": "^3.57",
        "spatie/laravel-honeypot": "^4.2",
        "statikbe/laravel-cookie-consent": "^1.3",
        "symfony/http-client": "^6.0",
        "symfony/postmark-mailer": "^6.0",
        "tanmuhittin/laravel-google-translate": "^2.1",
        "tecnickcom/tcpdf": "^6.3"
    },
    "require-dev": {
        "fzaninotto/faker": "^1.4",
        "laravel/legacy-factories": "^1.1",
        "laravel/pint": "^0.2.3",
        "mockery/mockery": "^1.0",
        "nunomaduro/collision": "^7.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
